# Relays the KPS journal to the workload VM. The base image's fluent-bit.service
# is not reused: it gates on /etc/cloud-api-domains and uploads to Cloud Logging,
# neither of which applies here. It stays inert on its own failed Condition.

[Unit]
Description=Fluent Bit log relay for Key Protection Service
After=network.target systemd-networkd.service
Wants=network.target

[Service]
Type=simple
ExecStartPre=/bin/mkdir -p /var/log/google-fluentbit
ExecStart=/usr/bin/fluent-bit -c /etc/fluent-bit/fluent-bit-kps.conf
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
