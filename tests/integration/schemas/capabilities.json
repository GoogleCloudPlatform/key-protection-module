{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "supported_algorithms": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "algorithm": {
            "type": "object",
            "properties": {
              "type": {"type": "string"},
              "params": {
                "type": "object",
                "properties": {
                  "kem_id": {"type": "string"}
                },
                "required": ["kem_id"],
                "additionalProperties": false
              }
            },
            "required": ["type", "params"],
            "additionalProperties": false
          }
        },
        "required": ["algorithm"],
        "additionalProperties": false
      }
    }
  },
  "required": ["supported_algorithms"],
  "additionalProperties": false
}
